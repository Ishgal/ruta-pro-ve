generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum Role {
  estudiante
  docente
  admin
}

enum SetupStatus {
  pending
  active
}

enum PlanTier {
  bronce
  plata
  oro
}

enum SubscriptionStatus {
  active
  cancelled
  expired
}

enum ProgressStatus {
  not_started
  in_progress
  completed
}

enum PaymentMethod {
  pago_movil
  binance_usdt
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum SkillCategory {
  technical
  soft
  language
}

enum SkillLevel {
  beginner
  intermediate
  advanced
}

enum SkillSource {
  test
  cv_analysis
  course
}

enum LessonType {
  video
  article
  quiz
  slides
}

enum MedalType {
  course
  level
  special
}

enum SubscriptionType {
  freemium
  premium
}

// ============================================================================
// MODELOS
// ============================================================================

model User {
  id               String               @id @default(uuid()) @db.Uuid
  email            String               @unique @db.VarChar(255)
  name             String               @db.VarChar(255)
  role             Role                 @default(estudiante)
  linkedinId       String?              @map("linkedin_id") @db.VarChar(255)
  avatarUrl        String?              @map("avatar_url") @db.VarChar(500)
  createdAt        DateTime?            @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime?            @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  lastSignInAt     DateTime?            @map("last_sign_in_at") @db.Timestamp(6)
  setupStatus      SetupStatus          @default(active) @map("setup_status")
  isActive         Boolean              @default(true) @map("is_active")
  plan             PlanTier             @default(bronce)
  certDiscounts    CertDiscount[]
  certificates     Certificate[]
  examAttempts     ExamAttempt[]
  levelCompletions LevelCompletion[]
  payments         Payment[]
  studentProfile   StudentProfile?
  subscriptions    Subscription[]
  teacherProfile   Teacher?
  badges           UserBadge[]
  courseProgress   UserCourseProgress[]
  lessonProgress   UserLessonProgress[]
  skills           UserSkill[]
  userStats        UserStats?
  teacherReviews   TeacherReview[]       // ← Reseñas escritas por este estudiante

  @@map("users")
}

model Teacher {
  id            String              @id @db.Uuid
  specialty     String[]
  studentsLimit Int?                @default(20) @map("students_limit")
  bio           String?
  hourlyRate    Int?                @map("hourly_rate")
  rating        Float?              @default(0)   // ← NUEVO: promedio de calificación (1-5)
  assignments   TeacherAssignment[]
  reviews       TeacherReview[]                    // ← NUEVO: reseñas recibidas
  user          User                @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("teachers")
}

model TeacherReview {
  id          String   @id @default(uuid()) @db.Uuid
  teacherId   String   @map("teacher_id") @db.Uuid
  studentId   String   @map("student_id") @db.Uuid
  courseId    String   @map("course_id") @db.Uuid
  rating      Int                 // 1 a 5
  comment     String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([teacherId, studentId, courseId])
  @@index([teacherId])
  @@map("teacher_reviews")
}

// El resto de tus modelos (UserStats, Level, Course, Lesson, etc.) se mantienen exactamente igual que los tenías,
// solo que se añade la relación inversa teacherReviews en Course.

model Course {
  id                 String               @id @default(uuid()) @db.Uuid
  title              String               @db.VarChar(255)
  description        String?
  levelId            Int                  @map("level_id")
  duration           String?              @db.VarChar(50)
  thumbnailUrl       String?              @map("thumbnail_url") @db.VarChar(500)
  skillsTags         String[]             @map("skills_tags")
  createdAt          DateTime?            @default(now()) @map("created_at") @db.Timestamp(6)
  isPublished        Boolean?             @default(false) @map("is_published")
  careers            String[]             @default([]) @map("careers")
  certificates       Certificate[]
  level              Level                @relation(fields: [levelId], references: [id])
  examAttempts       ExamAttempt[]
  lessons            Lesson[]
  teacherAssignments TeacherAssignment[]
  userProgress       UserCourseProgress[]
  teacherReviews     TeacherReview[]       // ← NUEVO: reseñas de profesores en este curso

  @@index([levelId], map: "idx_courses_level_id")
  @@map("courses")
}

// (Todos los demás modelos: Level, Lesson, UserCourseProgress, etc. déjalos exactamente como los tenías.
// El resto del archivo no ha cambiado, solo añadí los tres campos señalados.
// Abajo pongo el resto completo para que no haya omitido nada, pero si quieres ahorrar espacio,
// puedes mantener el tuyo y solo añadir los bloques de TeacherReview y las líneas indicadas).

// ============================================================================
// MODELOS RESTANTES (iguales a los tuyos)
// ============================================================================

model UserStats {
  userId                        String    @id @map("user_id") @db.Uuid
  totalCoursesCompleted         Int?      @default(0) @map("total_courses_completed")
  totalOptionalCoursesCompleted Int?      @default(0) @map("total_optional_courses_completed")
  totalXp                       Int?      @default(0) @map("total_xp")
  currentStreakDays             Int?      @default(0) @map("current_streak_days")
  longestStreak                 Int?      @default(0) @map("longest_streak")
  lastActivityDate              DateTime? @map("last_activity_date") @db.Date
  user                          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}

model Level {
  id               Int               @id
  name             String            @db.VarChar(50)
  description      String?
  displayOrder     Int               @map("display_order")
  courses          Course[]
  levelCompletions LevelCompletion[]

  @@map("levels")
}

model Lesson {
  id             String               @id @default(uuid()) @db.Uuid
  courseId       String               @map("course_id") @db.Uuid
  title          String               @db.VarChar(255)
  videoUrl       String?              @map("video_url") @db.VarChar(500)
  content        String?
  displayOrder   Int                  @map("display_order")
  duration       String?              @db.VarChar(50)
  isFreePreview  Boolean?             @default(false) @map("is_free_preview")
  lessonType     LessonType           @default(video) @map("lesson_type")
  quizData       Json?                @map("quiz_data")
  slidesUrl      String?              @map("slides_url") @db.VarChar(500)
  course         Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress       UserCourseProgress[]
  lessonProgress UserLessonProgress[]

  @@index([courseId], map: "idx_lessons_course_id")
  @@map("lessons")
}

model UserCourseProgress {
  id              String          @id @default(uuid()) @db.Uuid
  userId          String          @map("user_id") @db.Uuid
  courseId        String          @map("course_id") @db.Uuid
  status          ProgressStatus? @default(not_started)
  progressPercent Int?            @default(0) @map("progress_percent")
  currentLessonId String?         @map("current_lesson_id") @db.Uuid
  quizScore       Int?            @map("quiz_score")
  startedAt       DateTime?       @default(now()) @map("started_at") @db.Timestamp(6)
  completedAt     DateTime?       @map("completed_at") @db.Timestamp(6)
  course          Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  currentLesson   Lesson?         @relation(fields: [currentLessonId], references: [id])
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId], map: "idx_user_course_progress_user_id")
  @@index([status], map: "idx_user_course_progress_status")
  @@map("user_course_progress")
}

model LevelCompletion {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  levelId     Int       @map("level_id")
  isCompleted Boolean?  @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at") @db.Timestamp(6)
  level       Level     @relation(fields: [levelId], references: [id])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, levelId])
  @@index([userId, levelId], map: "idx_level_completion_user_level")
  @@map("level_completion")
}

model Badge {
  id             String      @id @default(uuid()) @db.Uuid
  name           String      @db.VarChar(100)
  description    String?
  conditionType  String?     @map("condition_type") @db.VarChar(50)
  conditionValue Int?        @map("condition_value")
  iconUrl        String?     @map("icon_url") @db.VarChar(500)
  userBadges     UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  badgeId   String    @map("badge_id") @db.Uuid
  awardedAt DateTime? @default(now()) @map("awarded_at") @db.Timestamp(6)
  badge     Badge     @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Certificate {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  courseId          String    @map("course_id") @db.Uuid
  qrCode            String    @unique @map("qr_code") @db.VarChar(255)
  pdfUrl            String?   @map("pdf_url") @db.VarChar(500)
  issuedAt          DateTime? @default(now()) @map("issued_at") @db.Timestamp(6)
  verificationCount Int?      @default(0) @map("verification_count")
  course            Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments          Payment[]

  @@unique([userId, courseId])
  @@index([qrCode], map: "idx_certificates_qr_code")
  @@map("certificates")
}

model TeacherAssignment {
  id         String    @id @default(uuid()) @db.Uuid
  teacherId  String    @map("teacher_id") @db.Uuid
  courseId   String    @map("course_id") @db.Uuid
  assignedAt DateTime? @default(now()) @map("assigned_at") @db.Timestamp(6)
  isActive   Boolean?  @default(true) @map("is_active")
  course     Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher    Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, courseId])
  @@map("teacher_assignments")
}

model Payment {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @map("user_id") @db.Uuid
  amount         Decimal        @db.Decimal(10, 2)
  method         PaymentMethod
  status         PaymentStatus? @default(pending)
  transactionId  String?        @map("transaction_id") @db.VarChar(255)
  paidAt         DateTime?      @map("paid_at") @db.Timestamp(6)
  createdAt      DateTime?      @default(now()) @map("created_at") @db.Timestamp(6)
  certificateId  String?        @map("certificate_id") @db.Uuid
  subscriptionId String?        @map("subscription_id") @db.Uuid
  originalAmount Decimal?       @map("original_amount") @db.Decimal(10, 2)
  paymentDate    DateTime?      @map("payment_date") @db.Timestamp(6)
  exchangeRate   Decimal?       @map("exchange_rate") @db.Decimal(12, 2)
  amountBs       Decimal?       @map("amount_bs") @db.Decimal(14, 2)
  certDiscount   CertDiscount?
  certificate    Certificate?   @relation(fields: [certificateId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subscription   Subscription?  @relation(fields: [subscriptionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_payments_user_id")
  @@index([status], map: "idx_payments_status")
  @@map("payments")
}

model Subscription {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  plan      PlanTier
  status    SubscriptionStatus @default(active)
  startedAt DateTime?          @default(now()) @map("started_at") @db.Timestamp(6)
  expiresAt DateTime?          @map("expires_at") @db.Timestamp(6)
  createdAt DateTime?          @default(now()) @map("created_at") @db.Timestamp(6)
  payments  Payment[]
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("subscriptions")
}

model CertDiscount {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  discountPct Int       @map("discount_pct")
  usedAt      DateTime? @map("used_at") @db.Timestamp(6)
  expiresAt   DateTime  @map("expires_at") @db.Timestamp(6)
  paymentId   String?   @unique @map("payment_id") @db.Uuid
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  payment     Payment?  @relation(fields: [paymentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("cert_discounts")
}

model StudentProfile {
  userId              String    @id @map("user_id") @db.Uuid
  educationLevel      String    @map("education_level") @db.VarChar(50)
  career              String    @db.VarChar(50)
  university          String?   @db.VarChar(255)
  academicYear        String?   @map("academic_year") @db.VarChar(50)
  graduationYear      Int?      @map("graduation_year")
  hasWorkExperience   Boolean   @map("has_work_experience")
  workExperienceYears Int?      @map("work_experience_years")
  jobRole             String?   @map("job_role") @db.VarChar(255)
  employmentStatus    String    @map("employment_status") @db.VarChar(50)
  primaryGoal         String    @map("primary_goal") @db.VarChar(50)
  timeline            String    @db.VarChar(50)
  declaredStrengths   Json      @default("[]") @map("declared_strengths")
  weeklyHours         String    @map("weekly_hours") @db.VarChar(50)
  location            String    @db.VarChar(100)
  workModality        String    @map("work_modality") @db.VarChar(50)
  cvUrl               String?   @map("cv_url") @db.VarChar(500)
  cvAnalysisNotes     String?   @map("cv_analysis_notes")
  onboardingChat      Json?     @map("onboarding_chat")
  aiProfileSummary    String?   @map("ai_profile_summary")
  knowledgeAssessment Json?     @map("knowledge_assessment")
  assignedStartLevel  Int       @default(1) @map("assigned_start_level")
  completedAt         DateTime? @map("completed_at") @db.Timestamp(6)
  generatedRoute      Json?     @map("generated_route")
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("student_profiles")
}

model AppSetting {
  key       String    @id @db.VarChar(100)
  value     String
  label     String?   @db.VarChar(255)
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("app_settings")
}

model PaymentAccount {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  method       String    @db.VarChar(50)
  label        String    @db.VarChar(100)
  isActive     Boolean   @default(true) @map("is_active")
  details      Json      @default("{}")
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("payment_accounts")
}

model Skill {
  id         String        @id @default(uuid()) @db.Uuid
  name       String        @unique @db.VarChar(100)
  category   SkillCategory
  userSkills UserSkill[]

  @@map("skills")
}

model UserSkill {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String      @map("user_id") @db.Uuid
  skillId    String      @map("skill_id") @db.Uuid
  level      SkillLevel
  source     SkillSource
  detectedAt DateTime?   @default(now()) @map("detected_at") @db.Timestamp(6)
  skill      Skill       @relation(fields: [skillId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId, source])
  @@index([userId], map: "idx_user_skills_user_id")
  @@map("user_skills")
}

model UserLessonProgress {
  userId      String   @map("user_id") @db.Uuid
  lessonId    String   @map("lesson_id") @db.Uuid
  completedAt DateTime @map("completed_at") @db.Timestamp(6)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([userId, lessonId])
  @@index([userId], map: "idx_user_lesson_progress_user_id")
  @@map("user_lesson_progress")
}

model ExamAttempt {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId    String    @map("course_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  examData    Json      @map("exam_data")
  answers     Json?
  score       Int?
  passed      Boolean   @default(false)
  startedAt   DateTime  @default(now()) @map("started_at") @db.Timestamp(6)
  completedAt DateTime? @map("completed_at") @db.Timestamp(6)
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_exam_attempts_user_id")
  @@index([courseId, userId], map: "idx_exam_attempts_course_user")
  @@map("exam_attempts")
}